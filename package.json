{
  "name": "pixa",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,md,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,md,json,css}\"",
    "clean": "rm -rf apps/*/.next apps/*/dist apps/*/.turbo apps/*/.vite .turbo node_modules/.cache"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
